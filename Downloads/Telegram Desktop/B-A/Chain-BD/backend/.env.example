# ScyllaDB (connect to your container)
SCYLLA_HOSTS=scylla-db  # Or localhost if standalone
SCYLLA_PORT=9042
SCYLLA_USERNAME=
SCYLLA_PASSWORD=

# Etherscan (required for tx confirmation/metadata)
ETHERSCAN_API_KEY=YourFreeKeyFromEtherscanIo  # Get at etherscan.io/myapikey

# Node (optional fallback for raw data)
MY_NODE_RPC_URLS=  # e.g., http://localhost:8545 for Geth
PREFER_NODE=false  # Set true later to use node first

# App
APP_HOST=0.0.0.0
APP_PORT=8001
DEBUG=True